# Database
DATABASE_URL=sqlite:///./ocr_system.db

# Authentication (CHANGE IN PRODUCTION)
SECRET_KEY=change-me-in-production-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# OCR
OCR_LANGUAGES=en,hi

# File Upload
MAX_FILE_SIZE_MB=20
ALLOWED_EXTENSIONS=png,jpg,jpeg,bmp,tiff,tif,pdf

# Rate Limiting
RATE_LIMIT=10/minute

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/ocr_system.log
LOG_ROTATION=10 MB
LOG_RETENTION=7 days

# Server
HOST=0.0.0.0
PORT=8000
